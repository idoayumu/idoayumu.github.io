---
interface Props {
  title: string;
  currentPath?: string;
}
const { title, currentPath = "" } = Astro.props;
const siteName = "光の記録　ー光景ノオトー";
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {siteName}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <div class="site-wrapper">
      <header class="site-header">
        <div class="site-header-inner">
          <a href="/" class="site-logo">{siteName}</a>
          <nav class="site-nav">
            <a href="/works" class={currentPath.startsWith("/works") ? "active" : ""}>Works</a>
            <a href="/models" class={currentPath.startsWith("/models") ? "active" : ""}>Models</a>
          </nav>
        </div>
      </header>
      <main><slot /></main>
      <footer class="site-footer">
        <p>&copy; {new Date().getFullYear()} {siteName}</p>
      </footer>
    </div>
  </body>
</html>
