---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "光の記録　ー光景ノオトー" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-title">光の記録　ー光景ノオトー</a>
        <nav class="site-nav">
          <a href="/works/">Works</a>
          <a href="/models/">Models</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>© 井戸歩</p>
    </footer>
  </body>
</html>