---
import Layout from "../../layouts/Layout.astro";
import worksData from "../../data/works.json";
import modelsData from "../../data/models.json";

const works = worksData.map((work) => {
  const relatedModels = modelsData.filter(
    (model) => Array.isArray(work.models) && work.models.includes(model.id)
  );

  return {
    ...work,
    modelNames: relatedModels.map((model) => model.name).join("・"),
  };
});
---

<Layout title="Works | 光の記録　ー光景ノオトー">
  <section>
    <h1>Works</h1>
    <p>{works.length}作品</p>

    <div class="works-grid">
      {works.map((work) => (
        <a href={`/works/${work.id}/`} class="work-card">
          <div class="work-thumb-wrap">
            <img
              src={`/images/works/${work.files[0].name}`}
              alt={work.files[0].alt || work.title}
              class="work-thumb"
            />
          </div>
          <h3>{work.title}</h3>
          <p class="work-meta">
            {work.modelNames && `${work.modelNames} ・ `}{work.date}
          </p>
        </a>
      ))}
    </div>
  </section>
</Layout>